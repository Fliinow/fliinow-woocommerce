{
    "name": "fliinow/fliinow-checkout",
    "description": "Fliinow checkout financing payment method for WooCommerce",
    "type": "wordpress-plugin",
    "require-dev": {
        "phpunit/phpunit": "^9.6"
    },
    "scripts": {
        "test": "phpunit",
        "test:unit": "phpunit --testsuite=unit",
        "test:integration": "phpunit --testsuite=integration"
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    }
}
